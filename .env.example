# Quran Platform Environment Variables

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/quran_platform?schema=public"

# ============================================
# APPLICATION
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Quran Platform"

# ============================================
# RATE LIMITING (Upstash Redis - optional)
# ============================================
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ============================================
# PRAYER TIMES
# ============================================
# AlAdhan API is free and requires no key
NEXT_PUBLIC_ALADHAN_API="https://api.aladhan.com/v1"
